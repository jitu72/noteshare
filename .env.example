# ---- Database ----
# MongoDB connection string. For local dev use a local mongod or MongoDB Atlas.
# Example (Atlas): mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017
# Database name to use inside the cluster.
MONGODB_DB=note_app

# ---- Auth ----
# Secret used to sign session JWTs. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-secret

# ---- Cloudinary (file attachments) ----
# Create these from https://console.cloudinary.com/app/settings/api-keys
# IMPORTANT: keep the API secret out of source control; set it as an env var only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
